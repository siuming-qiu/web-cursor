# 复制为 .env.local 后填值：cp .env.example .env.local
# 只列代码真实读取的变量。变量名以 server/ 下的实现为准，不要凭 README 记忆填写。

# ---- 基础闭环（对话 → 写文件 → 预览）必填 ----

# Postgres 连接串（Neon）。npm run db:push 也读这个。
DATABASE_URL=

# agent loop 与代码补全的 LLM key。
# 注意：baseURL 硬编码为 https://api.deepseek.com（server/llm.ts），没有 *_BASE_URL 变量。
DEEPSEEK_API_KEY=

# Vercel Blob 读写 token，由 @vercel/blob SDK 自行读取（附件与生成图都存这里）。
BLOB_READ_WRITE_TOKEN=

# ---- 生图 / 图片附件识别（用到才填）----

YUNWU_API_KEY=
# 可选：覆盖默认生图模型。
# YUNWU_IMAGE_MODEL=

# ---- Figma 集成（用到才填）----

FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
# 加密落库的 Figma token；配了 Figma 就必填。
FIGMA_TOKEN_ENCRYPTION_KEY=
# 可选：默认按请求 origin 推导为 {origin}/api/integrations/figma/oauth/callback
# FIGMA_REDIRECT_URI=
# 可选：目前只支持 rest
# FIGMA_PROVIDER=rest

# ---- 生图 runner ----

# 保护 /api/image-runner。生产环境未配置时该接口一律 401；本地开发放行。
# CRON_SECRET=
# IMAGE_RUNNER_SECRET=

# 本地 runner 脚本 scripts/image-runner-dev.mjs 使用。
# IMAGE_RUNNER_URL=http://localhost:3000/api/image-runner
# IMAGE_RUNNER_INTERVAL_MS=2000
# IMAGE_RUNNER_BATCH_SIZE=4

# ---- 其他 ----

# 站点绝对地址，用于 sitemap / robots。
# NEXT_PUBLIC_SITE_URL=
